# Copy to .env and fill in values (never commit .env)

MONGODB_URI=
REDIS_URL=
JWT_SECRET=

# Azure Blob (uploads) — use connection string OR account SAS URL; see src/services/azureBlob.js
AZURE_STORAGE_CONNECTION_STRING=
# Or BLOB_URL= (account or container SAS URL)
BLOB_URL=
AZURE_STORAGE_CONTAINER_NAME=

# AWS S3 (legacy / optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
